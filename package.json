{
  "name": "favor-report-builder",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute favor-reports --local --file=db/schema.sql",
    "db:seed": "wrangler d1 execute favor-reports --local --file=db/seed.sql",
    "pages:dev": "wrangler pages dev ./dist"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260403.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wrangler": "^4.80.0"
  }
}
